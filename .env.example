# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# =====================================================================
# SECURITY: API keys should NEVER be in VITE_* vars (they leak to browser!)
# Use proxy URLs instead. Deploy proxy workers from /proxy/ directory.
# =====================================================================

# Groq API — deploy proxy/groq-worker.js to Cloudflare Workers
# Set GROQ_API_KEY as a Worker env var, NOT here
VITE_GROQ_PROXY_URL=https://shinko-groq-proxy.your-subdomain.workers.dev/v1/chat/completions
# Fallback for local dev only (INSECURE — key exposed in browser):
VITE_GROQ_API_KEY=

# Claude API (AI Tutor) — deploy proxy/cloudflare-worker.js to Cloudflare Workers
# Set ANTHROPIC_API_KEY as a Worker env var, NOT here
VITE_ANTHROPIC_PROXY_URL=https://shinko-claude-proxy.your-subdomain.workers.dev/v1/messages
VITE_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Sentry error tracking (optional)
VITE_SENTRY_DSN=

# Default admin password — REQUIRED in production (omit to disable auto-creation)
# In dev mode, falls back to 'superadmin' if not set
VITE_DEFAULT_ADMIN_PW=

# Google Cloud Speech-to-Text (optional — falls back to Web Speech API)
# SECURITY: Prefer PROXY_URL to keep API key server-side
VITE_GOOGLE_STT_PROXY_URL=
# INSECURE — key exposed in browser bundle, use for local dev only:
VITE_GOOGLE_STT_API_KEY=

# PostHog Analytics (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=
