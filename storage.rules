rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User-scoped uploads — each user can only write to their own folder
    // Only allow safe content types (images, audio, video)
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|audio/.*|video/.*|application/pdf');
    }

    // Shared content — admin-only writes, all authenticated reads
    match /shared/{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Everything else — read-only for authenticated users
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
